# Secrets — every .env variant is ignored, but the template is committed.
.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# Build / packaging
build/
dist/

# Frontend build artifacts (regenerated by Dockerfile stage 1; produced
# locally by `cd soc_claw/frontend/styles && npm run build`).
# package-lock.json is intentionally NOT ignored — commit it for
# reproducible image builds.
soc_claw/frontend/static/
soc_claw/frontend/styles/node_modules/

# Benchmark output (regenerated each run)
soc_claw/benchmark/results/*.csv

# Data
data/

