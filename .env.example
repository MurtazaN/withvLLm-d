# SOC-Claw configuration.
#
# Copy this file to `.env` (which is gitignored) and fill in the blanks.
#
# In production (k8s, CI), env vars are injected by the orchestrator and
# no .env file is read.
#
# Variables fall into three groups: local-inference, cloud-inference, and
# the runtime-routing model name.
# Pure-cloud deployments can leave the local-inference variables blank.
# Pure-local deployments can leave the cloud-inference variables blank.

# --- Local inference (host vLLM) ---

# Required only for local inference. Used by `vllm serve` at startup to
# pull model weights from HuggingFace Hub. Not consumed by the soc-claw
# Python runtime.
HF_TOKEN=

# Where the soc-claw runtime reaches vLLM.
#   - Host shell:        http://localhost:8000/v1   (default if blank)
#   - docker-compose:    overridden in docker-compose.yml to
#                        http://host.docker.internal:8000/v1
SOC_CLAW_LOCAL_VLLM_URL=http://localhost:8000/v1

# --- Cloud inference (NVIDIA hosted Nemotron) ---

# Required only if the privacy router ever returns "cloud" for a prompt.
# Pure-local deployments can leave this blank.
NVIDIA_API_KEY=

# Cloud endpoint. Override only if NVIDIA changes the integrate URL.
SOC_CLAW_CLOUD_URL=https://integrate.api.nvidia.com/v1

# --- Model selection ---

# Model name passed to vLLM on local route, and to NVIDIA on cloud route.
# Must match what `vllm serve <name>` was launched with for local route.
SOC_CLAW_MODEL=nvidia/Nemotron-Mini-4B-Instruct

# --- Benchmark output ---

# Where benchmark/harness.py writes its CSV results.
#   - Host dev:        leave blank → defaults to soc_claw/benchmark/results/
#   - docker-compose:  Dockerfile sets /app/soc_claw/benchmark/results, mounted to
#                      ./soc_claw/benchmark/results on the host
#   - Production:      point at a mounted PVC or shared volume
BENCHMARK_OUTPUT_DIR=

# --- Authentication (FastAPI session cookies + CSRF) ---

# Secret used to sign session cookies and CSRF tokens. MUST be stable
# across restarts — if it changes, every active session and CSRF token
# is invalidated and users get logged out.
#
# In production, inject via k8s Secret / orchestrator env var.
# Generate locally with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# If left blank, soc_claw.backend.auth generates a one-shot key at
# startup (sessions don't survive a restart). Acceptable for dev; not
# acceptable for any deploy where users actually log in.
SOC_CLAW_SECRET_KEY=

# Comma-separated list of analyst credentials in the form
# "username:bcrypt_hash". Generate a hash with:
#   python -m soc_claw.backend.auth <plaintext-password>
#
# Example:
#   SOC_CLAW_USERS=alice:$2b$12$abc...,bob:$2b$12$def...
#
# If left blank, a default `analyst` / `analyst` account is created and
# a warning is logged at startup. Do NOT use the default in production.
SOC_CLAW_USERS=

# Session lifetime in seconds. Default 28800 (8 hours) — a typical SOC
# shift. Sessions older than this are rejected on the next request.
SOC_CLAW_SESSION_MAX_AGE=28800

# --- Observability (JSON logs + OpenTelemetry tracing) ---

# OTEL collector endpoint (gRPC). Examples:
#   - Local Jaeger (all-in-one):  http://localhost:4317
#   - Tempo / Datadog Agent:      whatever your agent exposes on :4317
# Leave blank to disable tracing entirely (no-op tracers, dev default).
OTEL_EXPORTER_OTLP_ENDPOINT=

# Threshold for the JSON logger. Server defaults to INFO; the harness
# defaults to WARNING (override here for CI / production). Valid values:
# DEBUG, INFO, WARNING, ERROR.
SOC_CLAW_LOG_LEVEL=INFO

# Optional file sink. When set, JSON logs are appended to this path
# instead of stderr. Useful for CI / harness runs where stderr should
# stay clean. In Docker, mount the path so the file survives restarts.
SOC_CLAW_LOG_FILE=
