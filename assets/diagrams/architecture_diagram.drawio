<mxfile host="Electron">
  <diagram name="Deployment Architecture" id="deployment-arch">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Title and Top Line -->
        <mxCell id="titleCircle" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#2DD4BF;strokeColor=none;" vertex="1">
          <mxGeometry x="40" y="45" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="title" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#2DD4BF;" value="SOC-Claw Deployment Architecture Diagram" vertex="1">
          <mxGeometry x="100" y="45" width="600" height="40" as="geometry" />
        </mxCell>
        <mxCell id="titleLine" parent="1" style="endArrow=none;html=1;strokeColor=#2DD4BF;strokeWidth=2;" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="80" y="65" />
            <mxPoint x="100" y="65" />
          </mxGeometry>
        </mxCell>
        
        <!-- Bottom Line (like in reference) -->
        <mxCell id="bottomLine" parent="1" style="endArrow=none;html=1;strokeColor=#2DD4BF;strokeWidth=2;startArrow=oval;startFill=1;endArrow=oval;endFill=1;" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="40" y="740" />
            <mxPoint x="1360" y="740" />
          </mxGeometry>
        </mxCell>

        <!-- Groups -->
        <mxCell id="ext_access_group" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#14B8A6;strokeWidth=1.5;dashed=1;dashPattern=4 4;fontColor=#94A3B8;align=center;verticalAlign=top;spacingTop=10;fontStyle=1;fontSize=14;" value="External Access" vertex="1">
          <mxGeometry x="40" y="140" width="160" height="440" as="geometry" />
        </mxCell>

        <mxCell id="backend_group" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#14B8A6;strokeWidth=1.5;dashed=1;dashPattern=4 4;fontColor=#94A3B8;align=center;verticalAlign=top;spacingTop=10;fontStyle=1;fontSize=14;" value="Docker Environment (Backend)" vertex="1">
          <mxGeometry x="480" y="140" width="300" height="440" as="geometry" />
        </mxCell>

        <mxCell id="inference_group" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#14B8A6;strokeWidth=1.5;dashed=1;dashPattern=4 4;fontColor=#94A3B8;align=center;verticalAlign=top;spacingTop=10;fontStyle=1;fontSize=14;" value="Inference Layer" vertex="1">
          <mxGeometry x="880" y="140" width="260" height="240" as="geometry" />
        </mxCell>

        <mxCell id="data_group" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#14B8A6;strokeWidth=1.5;dashed=1;dashPattern=4 4;fontColor=#94A3B8;align=center;verticalAlign=top;spacingTop=10;fontStyle=1;fontSize=14;" value="Data Service" vertex="1">
          <mxGeometry x="880" y="420" width="260" height="160" as="geometry" />
        </mxCell>

        <!-- External Nodes -->
        <mxCell id="analyst_pc" parent="1" style="rounded=1;arcSize=15;whiteSpace=wrap;html=1;fillColor=#4C1D95;strokeColor=#8B5CF6;strokeWidth=2;fontColor=#FFFFFF;fontStyle=1;fontSize=14;" value="PC End&#10;(Analyst UI)" vertex="1">
          <mxGeometry x="70" y="320" width="100" height="80" as="geometry" />
        </mxCell>

        <mxCell id="internet" parent="1" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#064E3B;strokeColor=#10B981;strokeWidth=2;fontColor=#FFFFFF;fontStyle=1;fontSize=13;" value="Internet" vertex="1">
          <mxGeometry x="240" y="330" width="100" height="60" as="geometry" />
        </mxCell>

        <mxCell id="firewall" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#991B1B;strokeColor=#DC2626;strokeWidth=2;fontColor=#FFFFFF;fontStyle=1;fontSize=13;" value="Firewall" vertex="1">
          <mxGeometry x="380" y="335" width="60" height="50" as="geometry" />
        </mxCell>

        <!-- Backend Nodes -->
        <mxCell id="api_gateway" parent="1" style="rounded=1;arcSize=15;whiteSpace=wrap;html=1;fillColor=#312E81;strokeColor=#6366F1;strokeWidth=2;fontColor=#FFFFFF;fontStyle=1;fontSize=13;" value="API &amp; Auth Routers&#10;(FastAPI)" vertex="1">
          <mxGeometry x="520" y="210" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="orchestrator" parent="1" style="rounded=1;arcSize=15;whiteSpace=wrap;html=1;fillColor=#312E81;strokeColor=#6366F1;strokeWidth=2;fontColor=#FFFFFF;fontStyle=1;fontSize=13;" value="Agent Orchestrator&#10;(Triage → Verifier → Response)" vertex="1">
          <mxGeometry x="520" y="330" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="tools" parent="1" style="rounded=1;arcSize=15;whiteSpace=wrap;html=1;fillColor=#312E81;strokeColor=#6366F1;strokeWidth=2;fontColor=#FFFFFF;fontStyle=1;fontSize=13;" value="Tools Registry&#10;(IP, Asset, MITRE)" vertex="1">
          <mxGeometry x="520" y="450" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Inference Nodes -->
        <mxCell id="vllm" parent="1" style="rounded=1;arcSize=15;whiteSpace=wrap;html=1;fillColor=#312E81;strokeColor=#6366F1;strokeWidth=2;fontColor=#FFFFFF;fontStyle=1;fontSize=13;" value="Local vLLM&#10;(NVIDIA Nemotron)" vertex="1">
          <mxGeometry x="910" y="190" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="cloud" parent="1" style="rounded=1;arcSize=15;whiteSpace=wrap;html=1;fillColor=#312E81;strokeColor=#6366F1;strokeWidth=2;fontColor=#FFFFFF;fontStyle=1;fontSize=13;" value="Cloud Providers&#10;(OpenRouter / Vertex AI)" vertex="1">
          <mxGeometry x="910" y="290" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Data Nodes -->
        <mxCell id="json_db" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#1E3A8A;strokeColor=#3B82F6;strokeWidth=2;fontColor=#FFFFFF;fontStyle=1;fontSize=13;" value="JSON Data Stores&#10;(Alerts, Intel, Assets)" vertex="1">
          <mxGeometry x="910" y="470" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <!-- PC to Internet -->
        <mxCell id="edge1" edge="1" parent="1" source="analyst_pc" target="internet" style="endArrow=classic;html=1;strokeColor=#2DD4BF;strokeWidth=2;dashed=1;dashPattern=4 4;edgeStyle=orthogonalEdgeStyle;rounded=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Internet to Firewall -->
        <mxCell id="edge2" edge="1" parent="1" source="internet" target="firewall" style="endArrow=classic;html=1;strokeColor=#2DD4BF;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;rounded=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Firewall to API -->
        <mxCell id="edge3" edge="1" parent="1" source="firewall" target="api_gateway" style="endArrow=classic;html=1;strokeColor=#2DD4BF;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;rounded=1;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="480" y="360" />
              <mxPoint x="480" y="240" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- API to Orchestrator -->
        <mxCell id="edge4" edge="1" parent="1" source="api_gateway" target="orchestrator" style="endArrow=classic;html=1;strokeColor=#2DD4BF;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;rounded=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Orchestrator to Tools -->
        <mxCell id="edge5" edge="1" parent="1" source="orchestrator" target="tools" style="endArrow=classic;html=1;strokeColor=#2DD4BF;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;rounded=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Orchestrator to vLLM -->
        <mxCell id="edge6" edge="1" parent="1" source="orchestrator" target="vllm" style="endArrow=classic;html=1;strokeColor=#2DD4BF;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;rounded=1;">
          <mxGeometry relative="1" as="geometry">
             <Array as="points">
                <mxPoint x="810" y="360" />
                <mxPoint x="810" y="220" />
             </Array>
          </mxGeometry>
        </mxCell>

        <!-- Orchestrator to Cloud -->
        <mxCell id="edge7" edge="1" parent="1" source="orchestrator" target="cloud" style="endArrow=classic;html=1;strokeColor=#2DD4BF;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;rounded=1;">
          <mxGeometry relative="1" as="geometry">
             <Array as="points">
                <mxPoint x="810" y="360" />
                <mxPoint x="810" y="320" />
             </Array>
          </mxGeometry>
        </mxCell>

        <!-- Tools to DB -->
        <mxCell id="edge8" edge="1" parent="1" source="tools" target="json_db" style="endArrow=classic;html=1;strokeColor=#2DD4BF;strokeWidth=2;dashed=1;dashPattern=4 4;edgeStyle=orthogonalEdgeStyle;rounded=1;" value="&lt;div style=&quot;color:#94A3B8;background:#111111;padding:2px;&quot;&gt;Data Access&lt;/div&gt;">
          <mxGeometry relative="1" as="geometry">
             <Array as="points">
                <mxPoint x="810" y="480" />
                <mxPoint x="810" y="510" />
             </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
