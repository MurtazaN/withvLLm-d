        <mxCell id="response" parent="1" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#8B5CF6;strokeWidth=2;verticalAlign=top;align=left;shadow=1;" value="&lt;div style=&quot;padding:6px 4px;&quot;&gt;&lt;div&gt;&lt;span style=&quot;font-weight:bold;font-size:17px;color:#0F172A;&quot;&gt;Response Agent&lt;/span&gt; &lt;span style=&quot;background:#EDE9FE;color:#6D28D9;padding:2px 7px;border-radius:10px;font-size:10px;font-weight:bold;&quot;&gt;NO TOOLS&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size:12px;color:#64748B;margin-top:4px;&quot;&gt;Prioritized action plan&lt;/div&gt;&lt;div style=&quot;font-size:10px;font-weight:bold;color:#94A3B8;letter-spacing:1px;margin-top:14px;&quot;&gt;PLAN BY SEVERITY&lt;/div&gt;&lt;div style=&quot;font-size:11px;color:#0F172A;margin-top:4px;&quot;&gt;&lt;b style=&quot;color:#DC2626;&quot;&gt;P1&lt;/b&gt; isolate + block + escalate + forensics&lt;/div&gt;&lt;div style=&quot;font-size:11px;color:#0F172A;&quot;&gt;&lt;b style=&quot;color:#EA580C;&quot;&gt;P2&lt;/b&gt; block IOCs, ticket, notify owner&lt;/div&gt;&lt;div style=&quot;font-size:11px;color:#0F172A;&quot;&gt;&lt;b style=&quot;color:#CA8A04;&quot;&gt;P3&lt;/b&gt; investigate, watchlist, follow-up&lt;/div&gt;&lt;div style=&quot;font-size:11px;color:#0F172A;&quot;&gt;&lt;b style=&quot;color:#16A34A;&quot;&gt;P4&lt;/b&gt; log only, tune detection rule&lt;/div&gt;&lt;div style=&quot;font-size:10px;font-weight:bold;color:#94A3B8;letter-spacing:1px;margin-top:14px;&quot;&gt;OUTPUT&lt;/div&gt;&lt;div style=&quot;font-size:11px;color:#0F172A;&quot;&gt;Ordered steps with reasoning,&lt;br/&gt;urgency, and approval gates&lt;/div&gt;&lt;/div&gt;" vertex="1">
