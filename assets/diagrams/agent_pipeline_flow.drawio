        <mxCell id="triage" parent="1" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#10B981;strokeWidth=2;verticalAlign=top;align=left;shadow=1;" value="&lt;div style=&quot;padding:6px 4px;&quot;&gt;&lt;div&gt;&lt;span style=&quot;font-weight:bold;font-size:17px;color:#0F172A;&quot;&gt;Triage Agent&lt;/span&gt; &lt;span style=&quot;background:#D1FAE5;color:#047857;padding:2px 7px;border-radius:10px;font-size:10px;font-weight:bold;&quot;&gt;HAS TOOLS&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size:12px;color:#64748B;margin-top:4px;&quot;&gt;Enrich + score severity&lt;/div&gt;&lt;div style=&quot;font-size:10px;font-weight:bold;color:#94A3B8;letter-spacing:1px;margin-top:14px;&quot;&gt;TOOLS&lt;/div&gt;&lt;div style=&quot;background:#ECFDF5;color:#047857;font-family:monospace;font-size:11px;padding:3px 6px;border-radius:4px;margin-top:4px;&quot;&gt;ip_reputation()&lt;/div&gt;&lt;div style=&quot;background:#ECFDF5;color:#047857;font-family:monospace;font-size:11px;padding:3px 6px;border-radius:4px;margin-top:3px;&quot;&gt;mitre_lookup()&lt;/div&gt;&lt;div style=&quot;background:#ECFDF5;color:#047857;font-family:monospace;font-size:11px;padding:3px 6px;border-radius:4px;margin-top:3px;&quot;&gt;asset_lookup()&lt;/div&gt;&lt;div style=&quot;font-size:10px;font-weight:bold;color:#94A3B8;letter-spacing:1px;margin-top:12px;&quot;&gt;OUTPUT&lt;/div&gt;&lt;div style=&quot;font-size:12px;color:#0F172A;margin-top:3px;&quot;&gt;&lt;b&gt;P1&lt;/b&gt; / P2 / P3 / P4&lt;/div&gt;&lt;div style=&quot;font-size:11px;color:#64748B;&quot;&gt;+ confidence, IOCs, MITRE&lt;/div&gt;&lt;/div&gt;" vertex="1">
