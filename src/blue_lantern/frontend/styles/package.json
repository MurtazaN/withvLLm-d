{
  "name": "soc-claw-frontend",
  "private": true,
  "version": "0.0.0",
  "description": "Build pipeline for SOC-Claw's self-hosted CSS + fonts. Runs at image build time only — not shipped to runtime.",
  "scripts": {
    "build:fonts": "mkdir -p ../static/fonts && cp node_modules/@fontsource-variable/red-hat-display/files/red-hat-display-latin-wght-normal.woff2 ../static/fonts/red-hat-display.woff2 && cp node_modules/@fontsource-variable/red-hat-text/files/red-hat-text-latin-wght-normal.woff2 ../static/fonts/red-hat-text.woff2 && cp node_modules/@fontsource-variable/red-hat-mono/files/red-hat-mono-latin-wght-normal.woff2 ../static/fonts/red-hat-mono.woff2 && cp node_modules/material-symbols/material-symbols-outlined.woff2 ../static/fonts/material-symbols-outlined.woff2",
    "build:css": "tailwindcss -c tailwind.config.js -i input.css -o ../static/tailwind.css --minify",
    "build": "npm run build:fonts && npm run build:css"
  },
  "dependencies": {
    "@fontsource-variable/red-hat-display": "^5.1.0",
    "@fontsource-variable/red-hat-text": "^5.1.0",
    "@fontsource-variable/red-hat-mono": "^5.1.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "material-symbols": "^0.27.0",
    "tailwindcss": "^3.4.17"
  }
}